{
  "compileOnSave": false,
  "compilerOptions": {
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "module": "es2020",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "paths": {
      "ngx-gauge": [
        "./dist/ngx-gauge"
      ],
      "ngx-gauge/*": [
        "./dist/ngx-gauge/*"
      ]
    },
    "useDefineForClassFields": false
  },
  "exclude": [
    "**/*.spec.ts",
    "./dist/**"
  ]
}
